# Copy this file to /home/aurapanel.info/.config/community-site.env on the server.
AURAPANEL_COMMUNITY_DB_HOST=127.0.0.1
AURAPANEL_COMMUNITY_DB_PORT=3306
AURAPANEL_COMMUNITY_DB_NAME=aurapanel_community
AURAPANEL_COMMUNITY_DB_USER=aurapanel_community
AURAPANEL_COMMUNITY_DB_PASS=change_me

# Optional hardening
AURAPANEL_COMMUNITY_ALLOWED_ORIGINS=https://aurapanel.info,https://www.aurapanel.info
AURAPANEL_COMMUNITY_RATE_LIMIT_MAX=4
AURAPANEL_COMMUNITY_RATE_LIMIT_WINDOW=900
AURAPANEL_COMMUNITY_RATE_LIMIT_FILE=/tmp/aurapanel-community-rate-limit.json
